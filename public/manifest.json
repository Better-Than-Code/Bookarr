{
  "id": "/",
  "name": "Bookrr",
  "short_name": "Bookrr",
  "description": "A fully integrated book and audiobook media server, searcher, and reader suite with native tracker aggregation and local library management.",
  "lang": "en",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#0f172a",
  "theme_color": "#6366f1",
  "categories": ["books", "entertainment", "utilities"],
  "icons": [
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icon-maskable.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "https://picsum.photos/seed/bookrr-sc1/1280/720",
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Bookrr Full-Featured E-Book Reader"
    },
    {
      "src": "https://picsum.photos/seed/bookrr-sc2/720/1280",
      "sizes": "720x1280",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Bookrr Touch-Friendly Audiobook Interface"
    }
  ],
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "My Bookshelf",
      "url": "/#bookshelf",
      "description": "Browse and read your saved e-books",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "Audiobooks",
      "url": "/#audiobooks",
      "description": "Listen to your audiobooks",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192",
          "purpose": "any"
        }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "/?file-handler",
      "accept": {
        "application/epub+zip": [".epub"],
        "application/pdf": [".pdf"],
        "audio/mpeg": [".mp3"]
      },
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "share_target": {
    "action": "/?share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "dir": "ltr",
  "orientation": "any"
}
